DATABASE_URL=postgresql://username:password@host/database
SECRET_KEY=change-me
NVIDIA_API_BASE_URL=https://router.huggingface.co/v1
NVIDIA_API_KEY=replace-with-your-secret-key
NVIDIA_MODEL=google/gemma-4-31b-it:novita
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RESPONSE_TOKENS=700
AI_CANDIDATE_LIMIT=10
AI_MAX_QUESTION_LENGTH=500
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$

